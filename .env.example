# ─────────────────────────────────────────────────────────────
# BOSS — Environment Variables
# Copy this file to .env.local (web) or .env (api) and fill in
# your values. Never commit files containing real secrets.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# ── Database ──────────────────────────────────────────────────
# Direct Postgres connection (used by migrations and @boss/db)
# Found in: Supabase Dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Anthropic ─────────────────────────────────────────────────
# Found in: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth callbacks ────────────────────────────────────────────
# Full URL that Supabase redirects to after email verification / OAuth
BOSS_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# ── API server ────────────────────────────────────────────────
BOSS_API_PORT=4000
# HOST and PORT are aliases used by some deployment platforms
HOST=0.0.0.0
PORT=4000

# ── Feature flags ─────────────────────────────────────────────
# Set to "true" to enable (default: false)
BOSS_FLAG_AI_WORKFORCE=false

# ── Third-party provider adapters (optional) ──────────────────
# ServiceTitan integration
SERVICETITAN_APP_KEY=

# QuickBooks integration — set to "true" to use sandbox environment
QB_SANDBOX=true

# ── Web app (NEXT_PUBLIC_ vars are embedded in the browser bundle) ──
# These can be the same values as SUPABASE_URL / SUPABASE_ANON_KEY above.
# If unset, next.config.mjs falls back to the server-side names automatically.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Internal API base URL (used by web app server components)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Static token for internal ops/cs pages (optional — leave blank to disable)
NEXT_PUBLIC_STATIC_TOKEN=

# Password reset redirect URL (sent in reset emails)
BOSS_PASSWORD_RESET_URL=http://localhost:3000/auth/reset-password

# Set to "true" to enable demo mode (disables writes on web)
BOSS_WEB_DEMO=false
