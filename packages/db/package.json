{
  "name": "@boss/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "clean": "rm -rf dist",
    "migrate": "tsx src/migrate.ts",
    "validate-migrations": "tsx src/validateMigrations.ts"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsx": "^4.16.0",
    "@types/pg": "^8.11.0"
  },
  "dependencies": {
    "@boss/config": "workspace:*",
    "@boss/types": "workspace:*",
    "@boss/shared": "workspace:*",
    "pg": "^8.12.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "type": "module"
}
