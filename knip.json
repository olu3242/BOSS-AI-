{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/api": {
      "entry": ["src/server.ts", "src/devServer.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/web": {
      "project": ["src/**/*.ts", "app/**/*.{ts,tsx}"]
    },
    "apps/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/config": {
      "entry": ["eslint.base.js"],
      "project": ["*.js"]
    },
    "packages/db": {
      "entry": ["src/index.ts", "src/migrate.ts", "src/validateMigrations.ts", "src/__tests__/*.test.ts", "src/__tests__/rlsSetup.ts"],
      "project": ["src/**/*.ts", "vitest.*.config.ts"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "industry-packs/*": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "@anthropic-ai/sdk",
    "@supabase/supabase-js",
    "zod",
    "@boss/types",
    "@boss/shared",
  ],
  "ignoreBinaries": ["powershell"],
  "ignoreExportsUsedInFile": true
}
