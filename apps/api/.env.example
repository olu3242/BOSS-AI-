# BOSS API — local development template
# Copy to .env. Never commit populated credentials.

# Runtime
NODE_ENV=development
HOST=127.0.0.1
PORT=4000

# Database (required for authenticated organization/dashboard operations)
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/boss_dev

# Supabase server runtime
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<public-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>
# Optional HS256 fallback; prefer SUPABASE_URL/JWKS verification.
SUPABASE_JWT_SECRET=<jwt-secret>

# Application security
# Generate with: openssl rand -hex 32
BOSS_SECRET_VAULT_KEY=<64-character-hex-key>
CRON_SECRET=<random-secret>

# Optional providers
ANTHROPIC_API_KEY=<anthropic-api-key>
OPENAI_API_KEY=<openai-api-key>
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
RESEND_API_KEY=<resend-api-key>
SERVICETITAN_APP_KEY=
QB_SANDBOX=true

# Feature flags
BOSS_FLAG_AI_WORKFORCE=false
