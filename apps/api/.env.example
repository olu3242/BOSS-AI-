# BOSS API — Environment Variables
# Copy this file to .env and fill in real values before running the server.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
BOSS_API_PORT=3001
HOST=0.0.0.0

# ── AI ────────────────────────────────────────────────────────────────────────
# Anthropic API key — required for AI workforce and recommendation engine
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────────────────────
# Supabase JWT secret — required for verifying user tokens
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Security ──────────────────────────────────────────────────────────────────
# 32-byte AES-256 key for encrypting provider credentials at rest.
# Generate: openssl rand -hex 32
BOSS_SECRET_VAULT_KEY=your-32-byte-hex-key

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable the AI Workforce subsystem
BOSS_FLAG_AI_WORKFORCE=true

# ── Third-Party Integrations (optional) ───────────────────────────────────────
# QuickBooks sandbox mode ("true" = use sandbox endpoints)
QB_SANDBOX=true

# ServiceTitan integration app key
SERVICETITAN_APP_KEY=

# ─────────────────────────────────────────────────────────────
# BOSS API — Environment Variables
# Copy to .env for local development.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────
BOSS_API_PORT=4000
HOST=0.0.0.0
PORT=4000

# ── Feature flags ─────────────────────────────────────────────
BOSS_FLAG_AI_WORKFORCE=false

# ── Billing ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Communication ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Automation ────────────────────────────────────────────────
CRON_SECRET=<random-base64>

# ── Provider adapters (optional) ──────────────────────────────
SERVICETITAN_APP_KEY=
QB_SANDBOX=true
