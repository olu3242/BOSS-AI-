# ─────────────────────────────────────────────────────────────
# BOSS Web — Environment Variables
# Copy to .env.local for local development.
# ─────────────────────────────────────────────────────────────

# ── Supabase (server-side only — never exposed to browser) ────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ── Auth ──────────────────────────────────────────────────────
# Full URL Supabase redirects to after email verification / OAuth
BOSS_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Password reset redirect URL (sent in reset emails)
BOSS_PASSWORD_RESET_URL=http://localhost:3000/auth/reset-password

# ── Browser-exposed vars (NEXT_PUBLIC_) ───────────────────────
# next.config.mjs falls back to SUPABASE_URL / SUPABASE_ANON_KEY
# automatically, so these are optional if the server vars are set.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Internal API URL used by server components and /ops, /cs pages
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Static bearer token for /ops and /cs internal pages (optional)
NEXT_PUBLIC_STATIC_TOKEN=

# Set to "true" to enable demo / read-only mode
BOSS_WEB_DEMO=false
