# BOSS Web — local development template
# Copy to .env.local. Never commit populated credentials.

# Browser-safe Supabase values. The anon key is public but still project-specific.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<public-anon-key>
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000

# Server-only Supabase values used by Next.js route handlers/server components.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<public-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>

# Database (required after authentication for organization/dashboard data).
# For hosted environments use Supabase's Transaction Pooler and URL-encode the password.
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# Auth redirects
BOSS_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback
BOSS_PASSWORD_RESET_URL=http://localhost:3000/auth/reset-password

# Optional local features/providers
NEXT_PUBLIC_STATIC_TOKEN=
BOSS_WEB_DEMO=false
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
RESEND_API_KEY=<resend-api-key>
CRON_SECRET=<random-secret>
